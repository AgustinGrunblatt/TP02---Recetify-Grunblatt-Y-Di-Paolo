@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Bienvenido</h1>
</div>
<form action='@Url.Action("GenerarSugerencia", "Home")' method='POST' enctype="multipart/form-data">
    Nombre: <input type = "text" name = "Nombre" placeholder="Ingresar Nombre"/><br>
    Fecha de Nacimiento: <input type = "date" name = "Fecha" placeholder="Ingresar fecha de nacimiento"/><br>
    ¿Caliente o frío? 
    <input type = "radio" name = "Tipo" value="1">Caliente
    <input type = "radio" name = "Tipo" value="2">Frío <br>
    Presupuesto: <input type = "number" name = "Presupuesto" placeholder="¿Cuál será el presupuesto?"/><br>
    Cantidad de Personas: <input type = "number" name = "Cantidad" placeholder="¿Cuántas personas serán?"/><br>
    <input type="submit" value="Enviar">
    <input type="reset" value="Resetear">
</form>
